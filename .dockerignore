# Version control
.git/
.gitignore
.hg/
.svn/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
*.cover
.venv*
venv*

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo
*.sublime*
*.DS_Store

# Environment and secrets
.env
.env.*
*.env
*.pem
*.key
*.crt

# Temporary and local files
tmp/
temp/
*.tmp
*.bak
*.old
*.orig

# Documentation
README.md
LICENSE
TODO.md
DEPLOYMENT_INSTRUCTIONS.md

# Docker files
Dockerfile*
docker-compose*.yml

# Development database
/db/*.sqlite3

# Locale compiled files (will be compiled in container)
*.mo

# Coverage reports
htmlcov/
coverage.xml

# Lock files
*.lock

# Media files (use volumes in production)
/media/*
!/media/.gitignore

# Static files (will be collected)
/static/*
!/static/.gitignore

# Development scripts
/scripts/
!.gitignore

# Tests
/tests/
test_*
*_test.py

# Migrations that are already applied
# (keep only recent ones for faster builds)